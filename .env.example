# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
RELOAD=true

# Security
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
JWT_AUDIENCE=

# LLM provider
# The app uses an OpenAI-compatible client. Use OpenRouter directly with the
# default base URL below, or point this at a local LiteLLM proxy if needed.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-5-chat
OPENROUTER_CHAT_MODEL=
OPENROUTER_REASONING_EFFORT=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
OPENROUTER_COST_USD_TO_THB=36.0
OPENROUTER_CHAT_INPUT_COST_PER_TOKEN_USD=0.00000025
OPENROUTER_CHAT_OUTPUT_COST_PER_TOKEN_USD=0.0000015

CHAT_CONTEXT_CLASSIFIER_ENABLED=true
CHAT_CONTEXT_CLASSIFIER_CONFIDENCE_THRESHOLD=0.65
CHAT_CONTEXT_CLASSIFIER_MODEL=
CHAT_CONTEXT_CLASSIFIER_MAX_TOKENS=140

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=tiwmai-documents
SUPABASE_AVATAR_BUCKET=tiwmai-avatars
SUPABASE_OAUTH_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
USE_SUPABASE=true
USE_SUPABASE_STORAGE=true

# File Upload Settings
ALLOWED_EXTENSIONS=png,jpg,jpeg,tiff,bmp,gif,webp

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>

# Error monitoring
SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=true
SENTRY_ENVIRONMENT=development

# CORS Settings
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://localhost:3005,http://127.0.0.1:3005
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# Payment
STRIPE_PUBLIC_KEY=
STRIPE_PRIVATE_KEY=
STRIPE_WEBHOOK_SECRET=
